{
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(/c/Users/$USER/AppData/Roaming/npm/pnpm)",
      "Bash(command -v npm)",
      "Bash(npm exec:*)",
      "Bash(\"/d/repos/vocab-practice-app/apps/web/node_modules/.bin/tsc\" --noEmit -p apps/web/tsconfig.json)",
      "Bash(node_modules/.bin/tsc --noEmit)",
      "Bash(tasklist)",
      "Bash(netstat -ano)",
      "Bash(curl -s http://localhost:3000/)",
      "Bash(curl -s http://localhost:5173/)",
      "Bash(curl -s http://localhost:5173/src/index.css)",
      "Bash(taskkill /PID 36600 /F)",
      "Bash(taskkill /PID 36712 /F)",
      "Bash(node_modules/.bin/tsx src/seed.ts)",
      "WebSearch"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd D:/repos/vocab-practice-app && git add -A && git diff --cached --quiet && exit 0; MSG=$(git diff --cached | claude -p \"Write a single git commit message in conventional commit format (feat, fix, refactor, chore, style, test, docs). Output ONLY the commit message, nothing else. Keep it under 72 chars.\"); git commit -m \"$MSG\"",
            "statusMessage": "Committing changes..."
          }
        ]
      }
    ]
  }
}
